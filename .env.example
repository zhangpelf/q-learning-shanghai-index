# =============================================================================
# QLens Agent — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the placeholder values.
# NEVER commit the real `.env` file to version control.
#
#   cp .env.example .env
# =============================================================================

# OpenAI-compatible API endpoint (local router or Cloud proxy).
# Default: http://127.0.0.1:8046/v1
OPENAI_BASE_URL=http://127.0.0.1:8046/v1

# API key for the LLM router (REQUIRED — see infra docs for the key).
OPENAI_API_KEY=your-api-key-here

# Q-Learning model server URL (the backend that runs the trained weights).
# Default: http://127.0.0.1:8765
MARKET_API_BASE=http://127.0.0.1:8765

# GCP project ID (required when deploying to Cloud Run / Agent Engine).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP location / region (default: global).
GOOGLE_CLOUD_LOCATION=global

# GCS bucket for prompt-response logging (optional — omit to disable telemetry).
# LOGS_BUCKET_NAME=qlens-agent-logs

# ALLOW_ORIGINS for CORS (comma-separated; omit to allow all).
# ALLOW_ORIGINS=http://localhost:5173,https://your-domain.com

# Published app URL for the A2A agent card (required for A2A / Agent Registry).
# APP_URL=http://localhost:8080
